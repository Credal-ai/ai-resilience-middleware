{
  "name": "ai-resilience-middleware",
  "version": "0.1.0",
  "description": "Resilience middleware for AI SDK streaming with retries and cross-provider fallbacks.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "typesVersions": {
    "*": {
      "*": ["./src/index.ts"]
    }
  },
  "files": ["src"],
  "scripts": {
    "test": "jest --config ./jest.config.cjs --runInBand",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@ai-sdk/provider": "*",
    "ai": "*"
  },
  "dependencies": {
    "serialize-error": "^12.0.0"
  }
}
